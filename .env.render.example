# Zani Render minimal environment.
# Use this file as a checklist for the current Render deploy.
# Do not commit real secrets. Paste real values in Render Dashboard -> Environment.

# -------------------------------------------------------------------
# Backend service: https://zani-9lnp.onrender.com
# -------------------------------------------------------------------

SECRET_KEY=replace-with-strong-32-plus-character-secret
DEBUG=False
ENVIRONMENT=staging
RELEASE=render
LOG_LEVEL=INFO
ALLOWED_HOSTS=zani-9lnp.onrender.com
WEB_CONCURRENCY=1
GUNICORN_TIMEOUT=120

# Supabase Postgres pooler URL.
# Example:
# postgresql://postgres.<project-ref>:<db-password>@aws-1-ap-northeast-1.pooler.supabase.com:6543/postgres?sslmode=require
DATABASE_URL=replace-with-supabase-pooler-database-url
DB_CONN_MAX_AGE=60

# Frontend origin allowed to call the backend.
CORS_ALLOWED_ORIGINS=https://zani-1.onrender.com
CORS_ALLOW_CREDENTIALS=False
CSRF_TRUSTED_ORIGINS=https://zani-1.onrender.com,https://zani-9lnp.onrender.com

# Render terminates TLS before Django.
SECURE_SSL_REDIRECT=True
SECURE_PROXY_SSL_HEADER=HTTP_X_FORWARDED_PROTO,https
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True

# JWT and public API rate limits.
JWT_ACCESS_TOKEN_MINUTES=15
JWT_REFRESH_TOKEN_DAYS=7
AUTH_LOGIN_RATE=10/min
AUTH_REFRESH_RATE=30/min
AUTH_SOCIAL_RATE=20/min
AUTH_SIGNUP_RATE=10/hour
AUTH_PASSWORD_RESET_RATE=5/hour
PUBLIC_API_RATE=120/min
PUBLIC_FORM_RATE=60/min
PUBLIC_WIDGET_RATE=120/min
INTEGRATION_WEBHOOK_RATE=300/min
AI_ASSISTANT_RATE=30/min

# Current no-Redis mode. Keep async/automation work inline until Redis/Celery is connected.
CELERY_TASK_ALWAYS_EAGER=True
CELERY_TASK_STORE_EAGER_RESULT=False
AUTOMATIONS_RUN_INLINE=True

# Current no-object-storage mode. Uploaded files are local to the Render instance.
# This is acceptable for demos only; use S3/R2/Supabase Storage before paid traffic.
USE_S3=False
STORAGE_BACKEND=local
STATIC_ROOT=/app/staticfiles
MEDIA_URL=media/
MEDIA_ROOT=/app/media
PRIVATE_MEDIA_ROOT=/app/media/private
MAX_UPLOAD_SIZE_MB=10

# OpenRouter is the only connected AI provider for now.
AI_ENABLED=True
AI_PROVIDER=openrouter
AI_MODEL=openrouter/auto
AI_FAST_MODEL=openrouter/auto
AI_SMART_MODEL=openrouter/auto
AI_CHEAP_MODEL=openrouter/auto
AI_DEFAULT_MODEL_TIER=smart
AI_PROMPT_MODEL_TIERS={"crm_assistant":"smart","lead_reply":"fast","client_summary":"smart","daily_summary":"smart","notification_summary":"cheap"}
AI_TEMPERATURE=0.4
AI_HTTP_TIMEOUT_SECONDS=20
OPENROUTER_API_KEY=replace-with-openrouter-api-key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_SITE_URL=https://zani-1.onrender.com
OPENROUTER_APP_NAME=ZANI

# No SMTP service is connected yet. Console backend prevents demo flows from failing on email send.
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=Zani <no-reply@zani.local>

# Access support data only through explicit grant flow.
SUPPORT_REQUIRES_GRANT=True
AUDIT_LOG_RETENTION_DAYS=365

# -------------------------------------------------------------------
# Frontend static site: https://zani-1.onrender.com
# -------------------------------------------------------------------

VITE_API_URL=https://zani-9lnp.onrender.com
VITE_GOOGLE_CLIENT_ID=
VITE_APPLE_CLIENT_ID=
