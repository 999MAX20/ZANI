# Zani staging backend env template.
# Copy to the deploy provider secrets/env UI. Do not commit real values.

SECRET_KEY=replace-with-strong-staging-secret-32-plus-chars
DEBUG=False
ENVIRONMENT=staging
RELEASE=staging-manual
LOG_LEVEL=INFO
ALLOWED_HOSTS=api-staging.zani.example
WEB_CONCURRENCY=2

# Managed PostgreSQL
DATABASE_URL=postgres://user:password@managed-postgres-host:5432/zani_staging?sslmode=require
DB_CONN_MAX_AGE=60

# Managed Redis / Celery
REDIS_URL=redis://default:password@managed-redis-host:6379/0
CELERY_WORKER_CONCURRENCY=2
CELERY_TASK_DEFAULT_QUEUE=default
CELERY_TASK_ACKS_LATE=True
CELERY_WORKER_PREFETCH_MULTIPLIER=1
AUTOMATIONS_RUN_INLINE=False

# Auth / throttling
JWT_ACCESS_TOKEN_MINUTES=15
JWT_REFRESH_TOKEN_DAYS=7
AUTH_LOGIN_RATE=10/min
AUTH_REFRESH_RATE=30/min
PUBLIC_API_RATE=120/min
PUBLIC_FORM_RATE=60/min
PUBLIC_WIDGET_RATE=120/min
INTEGRATION_WEBHOOK_RATE=300/min
AI_ASSISTANT_RATE=30/min

# CORS / CSRF
CORS_ALLOWED_ORIGINS=https://app-staging.zani.example
CORS_ALLOW_CREDENTIALS=False
CSRF_TRUSTED_ORIGINS=https://app-staging.zani.example

# HTTPS / security
SECURE_SSL_REDIRECT=True
SECURE_PROXY_SSL_HEADER=HTTP_X_FORWARDED_PROTO,https
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=False
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SUPPORT_REQUIRES_GRANT=True
AUDIT_LOG_RETENTION_DAYS=365

# Static / media
STATIC_ROOT=/app/staticfiles
MEDIA_URL=media/
MEDIA_ROOT=/app/media
PRIVATE_MEDIA_ROOT=/app/media/private
MAX_UPLOAD_SIZE_MB=10
ALLOWED_UPLOAD_EXTENSIONS=jpg,jpeg,png,webp,pdf,txt,doc,docx,xls,xlsx,mp3,ogg,wav
ALLOWED_UPLOAD_CONTENT_TYPES=image/jpeg,image/png,image/webp,application/pdf,text/plain,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document,application/vnd.ms-excel,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet,audio/mpeg,audio/ogg,audio/wav

# Observability
SENTRY_DSN=https://replace-with-staging-sentry-dsn
SENTRY_TRACES_SAMPLE_RATE=0.05

# Providers disabled by default for staging foundation
TELEGRAM_ENABLED=False
TELEGRAM_BASE_API_URL=https://api.telegram.org
TELEGRAM_WEBHOOK_SECRET=
WHATSAPP_ENABLED=False
INSTAGRAM_ENABLED=False
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_TEMPERATURE=0.4

# Transactional email
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.provider.example
EMAIL_PORT=587
EMAIL_HOST_USER=staging-user
EMAIL_HOST_PASSWORD=replace-with-staging-smtp-password
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=Zani Staging <no-reply-staging@zani.example>

# Object storage: prefer Supabase Storage or Cloudflare R2 for staging
USE_S3=True
STORAGE_BACKEND=s3
AWS_ACCESS_KEY_ID=replace-with-staging-storage-access-key
AWS_SECRET_ACCESS_KEY=replace-with-staging-storage-secret-key
AWS_STORAGE_BUCKET_NAME=zani-staging-private
AWS_S3_REGION_NAME=auto
AWS_S3_ENDPOINT_URL=https://replace-with-storage-endpoint
AWS_QUERYSTRING_AUTH=True
