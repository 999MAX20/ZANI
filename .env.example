# Django core
SECRET_KEY=change-me-use-32-plus-random-characters
DEBUG=True
ENVIRONMENT=development
RELEASE=local
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
WEB_CONCURRENCY=3

# Database
DATABASE_URL=sqlite:///db.sqlite3
# Local Docker/PostgreSQL:
# DATABASE_URL=postgres://zani_user:change-me@db:5432/zani
# Supabase/Postgres example:
# DATABASE_URL=postgres://postgres.your-project:your-password@aws-0-region.pooler.supabase.com:6543/postgres?sslmode=require
POSTGRES_DB=zani
POSTGRES_USER=zani_user
POSTGRES_PASSWORD=change-me
DB_CONN_MAX_AGE=60

# Redis / Celery
REDIS_URL=redis://redis:6379/0
CELERY_WORKER_CONCURRENCY=2

# Auth / JWT / throttling
JWT_ACCESS_TOKEN_MINUTES=15
JWT_REFRESH_TOKEN_DAYS=7
AUTH_LOGIN_RATE=10/min
AUTH_REFRESH_RATE=30/min

# CORS / CSRF
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174
CORS_ALLOW_CREDENTIALS=False
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174

# Security
SECURE_SSL_REDIRECT=False
SECURE_PROXY_SSL_HEADER=
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SUPPORT_REQUIRES_GRANT=False
AUDIT_LOG_RETENTION_DAYS=365

# Static / media
STATIC_ROOT=/app/staticfiles
MEDIA_URL=media/
MEDIA_ROOT=/app/media
PRIVATE_MEDIA_ROOT=/app/media/private
MAX_UPLOAD_SIZE_MB=10
ALLOWED_UPLOAD_EXTENSIONS=jpg,jpeg,png,webp,pdf,txt,doc,docx,xls,xlsx,mp3,ogg,wav
ALLOWED_UPLOAD_CONTENT_TYPES=image/jpeg,image/png,image/webp,application/pdf,text/plain,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document,application/vnd.ms-excel,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet,audio/mpeg,audio/ogg,audio/wav

# Sentry, optional
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.05

# Telegram
TELEGRAM_ENABLED=False
TELEGRAM_BASE_API_URL=https://api.telegram.org
TELEGRAM_WEBHOOK_SECRET=

# WhatsApp / Instagram placeholders
WHATSAPP_ENABLED=False
INSTAGRAM_ENABLED=False

# OpenAI, optional
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_TEMPERATURE=0.4

# Email
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=Zani <no-reply@zani.local>

# Object storage placeholders, implemented in a later step
USE_S3=False
STORAGE_BACKEND=local
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=
AWS_S3_ENDPOINT_URL=
AWS_QUERYSTRING_AUTH=True

# Frontend
VITE_API_URL=http://localhost:8000
