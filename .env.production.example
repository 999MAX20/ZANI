# Zani production backend env template.
# Put real values into production provider secrets.

SECRET_KEY=replace-with-unique-production-secret-32-plus-chars
DEBUG=False
ENVIRONMENT=production
RELEASE=production-release-sha
LOG_LEVEL=INFO
ALLOWED_HOSTS=api.zani.example
WEB_CONCURRENCY=3
GUNICORN_TIMEOUT=120

DATABASE_URL=
SUPABASE_PROJECT_REF=replace-with-production-project-ref
SUPABASE_DB_PASSWORD=replace-with-production-database-password
SUPABASE_DB_CONNECTION_MODE=pooler
SUPABASE_DB_POOLER_HOST=replace-with-production-pooler-host-from-supabase
SUPABASE_DB_PORT=6543
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=postgres.replace-with-production-project-ref
DB_CONN_MAX_AGE=60

REDIS_URL=redis://default:replace-with-password@replace-with-host:6379/0
CELERY_WORKER_CONCURRENCY=2
CELERY_AI_WORKER_CONCURRENCY=1
CELERY_TASK_DEFAULT_QUEUE=default
CELERY_TASK_ACKS_LATE=True
CELERY_WORKER_PREFETCH_MULTIPLIER=1
AUTOMATIONS_RUN_INLINE=False

JWT_ACCESS_TOKEN_MINUTES=15
JWT_REFRESH_TOKEN_DAYS=7
AUTH_LOGIN_RATE=10/min
AUTH_REFRESH_RATE=30/min
PUBLIC_API_RATE=120/min
PUBLIC_FORM_RATE=60/min
PUBLIC_WIDGET_RATE=120/min
INTEGRATION_WEBHOOK_RATE=300/min
AI_ASSISTANT_RATE=30/min

CORS_ALLOWED_ORIGINS=https://app.zani.example
CORS_ALLOW_CREDENTIALS=False
CSRF_TRUSTED_ORIGINS=https://app.zani.example

SECURE_PROXY_SSL_HEADER=HTTP_X_FORWARDED_PROTO,https
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True
SUPPORT_REQUIRES_GRANT=True
AUDIT_LOG_RETENTION_DAYS=365

STATIC_ROOT=/app/staticfiles
MEDIA_URL=media/
MEDIA_ROOT=/app/media
PRIVATE_MEDIA_ROOT=/app/media/private
MAX_UPLOAD_SIZE_MB=10

USE_S3=True
STORAGE_BACKEND=s3
AWS_ACCESS_KEY_ID=replace-with-production-storage-access-key
AWS_SECRET_ACCESS_KEY=replace-with-production-storage-secret-key
AWS_STORAGE_BUCKET_NAME=zani-production-private
AWS_S3_REGION_NAME=auto
AWS_S3_ENDPOINT_URL=https://replace-with-storage-endpoint
AWS_QUERYSTRING_AUTH=True

SENTRY_DSN=https://replace-with-production-sentry-dsn
SENTRY_TRACES_SAMPLE_RATE=0.05

TELEGRAM_ENABLED=False
TELEGRAM_BASE_API_URL=https://api.telegram.org
TELEGRAM_WEBHOOK_SECRET=
WHATSAPP_ENABLED=False
INSTAGRAM_ENABLED=False

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_TEMPERATURE=0.4

EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.provider.example
EMAIL_PORT=587
EMAIL_HOST_USER=production-user
EMAIL_HOST_PASSWORD=replace-with-production-smtp-password
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=Zani <no-reply@zani.example>
