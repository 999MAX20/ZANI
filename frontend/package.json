{
  "name": "zani-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "check:i18n": "node scripts/check-i18n.mjs",
    "test:action-feedback": "node --test scripts/tests/action-feedback-policy.test.mjs",
    "test:daily-workspaces": "node --test scripts/tests/daily-workspaces-policy.test.mjs",
    "check:bundle": "node scripts/check-bundle.mjs",
    "build": "npm run check:i18n && tsc -b && vite build && vite build --config widget/vite.config.ts",
    "preview": "vite preview --host 0.0.0.0",
    "audit:visual": "node scripts/visual-audit.mjs",
    "audit:interaction": "node scripts/interaction-audit.mjs",
    "lighthouse:ci": "npx @lhci/cli autorun",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:staging": "E2E_SKIP_LOCAL_SETUP=true playwright test --config=playwright.staging.config.ts"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fontsource-variable/manrope": "^5.3.0",
    "@gsap/react": "^2.1.2",
    "@hookform/resolvers": "^3.9.1",
    "@sentry/react": "^10.56.0",
    "@tanstack/react-query": "^5.59.20",
    "@tanstack/react-virtual": "^3.14.2",
    "axios": "^1.7.7",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "gsap": "^3.15.0",
    "lenis": "^1.3.23",
    "lucide-react": "^0.468.0",
    "posthog-js": "^1.379.3",
    "react": "^18.3.1",
    "react-countup": "^6.5.3",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.53.2",
    "react-intersection-observer": "^10.0.3",
    "react-router-dom": "^6.28.0",
    "split-type": "^0.3.4",
    "swiper": "^12.2.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss-animate": "^1.0.7",
    "write-excel-file": "^4.0.7",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.60.0",
    "@types/node": "^22.10.1",
    "@types/pngjs": "^6.0.5",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.4.20",
    "pixelmatch": "^7.2.0",
    "pngjs": "^7.0.0",
    "postcss": "^8.4.49",
    "rollup-plugin-visualizer": "^7.0.1",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.3",
    "vite": "^8.0.16"
  }
}
