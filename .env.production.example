# Zani backend production env template.
# Copy values into the production backend environment.
# Never commit real passwords, tokens or secrets.

SECRET_KEY=replace-with-strong-production-secret-32-plus-random-chars
DEBUG=False
ENVIRONMENT=production
RELEASE=production
LOG_LEVEL=INFO
ALLOWED_HOSTS=api.your-domain.com
WEB_CONCURRENCY=2
GUNICORN_TIMEOUT=120

# Production must use managed PostgreSQL with backups/PITR.
DATABASE_URL=postgresql://user:password@host:5432/database?sslmode=require
DB_CONN_MAX_AGE=60

# Optional Supabase split variables if DATABASE_URL is empty.
SUPABASE_PROJECT_REF=
SUPABASE_DB_PASSWORD=
SUPABASE_DB_CONNECTION_MODE=pooler
SUPABASE_DB_REGION=
SUPABASE_DB_POOLER_HOST=
SUPABASE_DB_HOST=
SUPABASE_DB_PORT=6543
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=

# Production queue runtime.
# Use the same Redis URL on backend web and every worker service.
# Prefer rediss:// when the provider supports TLS.
REDIS_URL=redis://user:password@host:6379/0
CELERY_WORKER_CONCURRENCY=2
CELERY_AI_WORKER_CONCURRENCY=1
CELERY_TASK_DEFAULT_QUEUE=default
CELERY_TASK_ACKS_LATE=True
CELERY_WORKER_PREFETCH_MULTIPLIER=1
CELERY_TASK_ALWAYS_EAGER=False
CELERY_TASK_STORE_EAGER_RESULT=False
AUTOMATIONS_RUN_INLINE=False

JWT_ACCESS_TOKEN_MINUTES=15
JWT_REFRESH_TOKEN_DAYS=7
AUTH_LOGIN_RATE=10/min
AUTH_REFRESH_RATE=30/min
AUTH_SOCIAL_RATE=20/min
AUTH_SIGNUP_RATE=10/hour
AUTH_PASSWORD_RESET_RATE=5/hour
PUBLIC_API_RATE=120/min
PUBLIC_FORM_RATE=60/min
PUBLIC_WIDGET_RATE=120/min
INTEGRATION_WEBHOOK_RATE=300/min
AI_ASSISTANT_RATE=30/min

CORS_ALLOWED_ORIGINS=https://app.your-domain.com
CORS_ALLOW_CREDENTIALS=False
CSRF_TRUSTED_ORIGINS=https://app.your-domain.com,https://api.your-domain.com

SECURE_SSL_REDIRECT=True
SECURE_PROXY_SSL_HEADER=HTTP_X_FORWARDED_PROTO,https
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SUPPORT_REQUIRES_GRANT=True
AUDIT_LOG_RETENTION_DAYS=730

STATIC_ROOT=/app/staticfiles
MEDIA_URL=media/
MEDIA_ROOT=/app/media
PRIVATE_MEDIA_ROOT=/app/media/private
MAX_UPLOAD_SIZE_MB=10

# Production files must use private object storage.
USE_S3=True
STORAGE_BACKEND=s3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=
AWS_S3_ENDPOINT_URL=
AWS_QUERYSTRING_AUTH=True

SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.05

TELEGRAM_ENABLED=False
TELEGRAM_BASE_API_URL=https://api.telegram.org
TELEGRAM_WEBHOOK_SECRET=
WHATSAPP_ENABLED=False
INSTAGRAM_ENABLED=False

# Optional social sign-in. These are allowed provider client IDs for ID-token validation, not provider secrets.
GOOGLE_OAUTH_CLIENT_IDS=
APPLE_OAUTH_CLIENT_IDS=
SOCIAL_AUTH_AUTO_CREATE_MERCHANT=True

# Central AI assistant provider.
# AI_PROVIDER can be: mock, kimi, openrouter, openai.
AI_ENABLED=True
AI_PROVIDER=mock
AI_MODEL=
AI_FAST_MODEL=kimi-k2.6
AI_SMART_MODEL=kimi-k2.6
AI_CHEAP_MODEL=kimi-k2.6
AI_DEFAULT_MODEL_TIER=smart
AI_PROMPT_MODEL_TIERS={"crm_assistant":"smart","lead_reply":"fast","client_summary":"smart","daily_summary":"smart","notification_summary":"cheap"}
AI_TEMPERATURE=0.4
AI_HTTP_TIMEOUT_SECONDS=20
KIMI_API_KEY=
KIMI_BASE_URL=https://api.moonshot.ai/v1
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_SITE_URL=https://app.your-domain.com
OPENROUTER_APP_NAME=ZANI
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini
OPENAI_TEMPERATURE=0.4

EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=Zani <no-reply@your-domain.com>

VITE_API_URL=https://your-production-api.example.com
VITE_GOOGLE_CLIENT_ID=
VITE_APPLE_CLIENT_ID=

PAID_BETA_STAGING_SMOKE_GREEN=False
PAID_BETA_BROWSER_E2E_GREEN=False
PAID_BETA_BACKUP_RESTORE_DRILL_DONE=False
PAID_BETA_SUPPORT_GRANT_FLOW_TESTED=False
