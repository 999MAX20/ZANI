# Local development env template. Copy to .env for local runs.

SECRET_KEY=change-me-use-32-plus-random-characters
DEBUG=True
ENVIRONMENT=development
ALLOW_DEMO_MERCHANT_FLOWS=True
RELEASE=local
LOG_LEVEL=INFO
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
WEB_CONCURRENCY=2
GUNICORN_TIMEOUT=120

# Local default DB. For Supabase/Render, use .env.staging.example.
DATABASE_URL=sqlite:///db.sqlite3
DB_CONN_MAX_AGE=60

# Optional Supabase split variables.
# If DATABASE_URL is empty, Django can build it from these values.
SUPABASE_PROJECT_REF=
SUPABASE_DB_PASSWORD=
SUPABASE_DB_CONNECTION_MODE=pooler
SUPABASE_DB_REGION=
SUPABASE_DB_POOLER_HOST=
SUPABASE_DB_HOST=
SUPABASE_DB_PORT=6543
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=

REDIS_URL=redis://redis:6379/0
CELERY_WORKER_CONCURRENCY=2
CELERY_TASK_DEFAULT_QUEUE=default
CELERY_TASK_ACKS_LATE=True
CELERY_WORKER_PREFETCH_MULTIPLIER=1
CELERY_TASK_ALWAYS_EAGER=False
CELERY_TASK_STORE_EAGER_RESULT=False
AUTOMATIONS_RUN_INLINE=True
OUTBOUND_MESSAGES_RUN_INLINE=True
OUTBOUND_DELIVERY_INTERVAL_SECONDS=30
OUTBOUND_DELIVERY_BATCH_SIZE=100
OUTBOUND_DELIVERY_MAX_ATTEMPTS=5
OUTBOUND_DELIVERY_RETRY_BASE_SECONDS=30
OUTBOUND_DELIVERY_RETRY_MAX_SECONDS=3600
OUTBOUND_DELIVERY_STALE_LOCK_SECONDS=900
CRM_COMMAND_IDEMPOTENCY_RETENTION_DAYS=7
CRM_COMMAND_IDEMPOTENCY_LOCK_SECONDS=300
CRM_COMMAND_IDEMPOTENCY_PRUNE_INTERVAL_SECONDS=3600

JWT_ACCESS_TOKEN_MINUTES=15
JWT_REFRESH_TOKEN_DAYS=7
AUTH_LOGIN_RATE=10/min
AUTH_REFRESH_RATE=30/min
AUTH_SOCIAL_RATE=20/min
AUTH_SIGNUP_RATE=10/hour
AUTH_PASSWORD_RESET_RATE=5/hour
PUBLIC_API_RATE=120/min
PUBLIC_FORM_RATE=60/min
PUBLIC_WIDGET_RATE=120/min
INTEGRATION_WEBHOOK_RATE=300/min
AI_ASSISTANT_RATE=30/min

CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CORS_ALLOW_CREDENTIALS=False
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

SECURE_SSL_REDIRECT=False
SECURE_PROXY_SSL_HEADER=
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SUPPORT_REQUIRES_GRANT=False
AUDIT_LOG_RETENTION_DAYS=365

STATIC_ROOT=/app/staticfiles
MEDIA_URL=media/
MEDIA_ROOT=/app/media
PRIVATE_MEDIA_ROOT=/app/media/private
MAX_UPLOAD_SIZE_MB=10
IMPORT_MAX_ROWS=5000
EXPORT_SYNC_MAX_ROWS=5000
EXPORT_MAX_ROWS=100000
REPORT_MAX_RANGE_DAYS=366
REPORT_EXPORT_SYNC_MAX_DAYS=90
EXPORT_STALE_SECONDS=900

USE_S3=False
STORAGE_BACKEND=local
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=
AWS_S3_ENDPOINT_URL=
AWS_QUERYSTRING_AUTH=True

SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.05

TELEGRAM_ENABLED=False
TELEGRAM_BASE_API_URL=https://api.telegram.org
TELEGRAM_WEBHOOK_SECRET=

# Meta connectors. These values are platform-level and are required before
# WhatsApp/Instagram can receive production webhooks.
WHATSAPP_ENABLED=False
WHATSAPP_GRAPH_BASE_URL=https://graph.facebook.com
WHATSAPP_GRAPH_API_VERSION=v25.0
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=
META_APP_ID=
META_APP_SECRET=
WHATSAPP_EMBEDDED_SIGNUP_CONFIG_ID=
WHATSAPP_EMBEDDED_SIGNUP_LOGIN_URL=https://www.facebook.com/dialog/oauth
INSTAGRAM_ENABLED=False
INSTAGRAM_GRAPH_BASE_URL=https://graph.facebook.com
INSTAGRAM_GRAPH_API_VERSION=v25.0
INSTAGRAM_VERIFY_TOKEN=
INSTAGRAM_APP_SECRET=

# Merchant data connectors. Enable only when a real merchant access key has
# been saved in the corresponding integration.
KASPI_ENABLED=False
KASPI_API_BASE_URL=https://kaspi.kz/shop/api/v2
KASPI_REPRICING_ENABLED=False
KASPI_REPRICING_WRITE_ENABLED=False
KASPI_REPRICING_SCHEDULE_ENABLED=False
KASPI_REPRICING_INTERVAL_SECONDS=1800
KASPI_REPRICING_APPLY_AUTOPILOT=False
KASPI_PRICE_WRITE_PROVIDER=price_feed
KASPI_PRICE_WRITE_API_URL=
KASPI_PRICE_WRITE_API_KEY=
KASPI_COMPETITOR_MONITOR_PROVIDER=mock
KASPI_COMPETITOR_MONITOR_API_URL=
KASPI_COMPETITOR_MONITOR_API_KEY=
MOYSKLAD_ENABLED=False
MOYSKLAD_API_BASE_URL=https://api.moysklad.ru/api/remap/1.2
WILDBERRIES_ENABLED=False
WILDBERRIES_STATISTICS_API_BASE_URL=https://statistics-api.wildberries.ru
OZON_ENABLED=False
OZON_SELLER_API_BASE_URL=https://api-seller.ozon.ru

# Central AI assistant provider.
# ZANI uses OpenRouter as the default external AI gateway.
AI_ENABLED=True
AI_PROVIDER=openrouter
AI_MODEL=openrouter/auto
AI_FAST_MODEL=openrouter/auto
AI_SMART_MODEL=openrouter/auto
AI_CHEAP_MODEL=openrouter/auto
AI_DEFAULT_MODEL_TIER=smart
AI_PROMPT_MODEL_TIERS={"crm_assistant":"smart","lead_reply":"fast","client_summary":"smart","daily_summary":"smart","notification_summary":"cheap"}
AI_TEMPERATURE=0.4
AI_HTTP_TIMEOUT_SECONDS=20
OPENROUTER_API_KEY=replace-with-openrouter-api-key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_SITE_URL=http://localhost:5173
OPENROUTER_APP_NAME=ZANI

# Optional social sign-in. These are allowed provider client IDs for ID-token validation, not provider secrets.
GOOGLE_OAUTH_CLIENT_IDS=
APPLE_OAUTH_CLIENT_IDS=
SOCIAL_AUTH_AUTO_CREATE_MERCHANT=True

EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=Zani <no-reply@zani.local>

PAID_BETA_STAGING_SMOKE_GREEN=False
PAID_BETA_BROWSER_E2E_GREEN=False
PAID_BETA_BACKUP_RESTORE_DRILL_DONE=False
PAID_BETA_SUPPORT_GRANT_FLOW_TESTED=False

VITE_API_URL=http://localhost:8000
VITE_GOOGLE_CLIENT_ID=
VITE_APPLE_CLIENT_ID=
