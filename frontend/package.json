{
  "name": "zani-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "check:i18n": "node scripts/check-i18n.mjs",
    "build": "npm run check:i18n && tsc -b && vite build && vite build --config widget/vite.config.ts",
    "preview": "vite preview --host 0.0.0.0",
    "lighthouse:ci": "npx @lhci/cli autorun",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:staging": "E2E_SKIP_LOCAL_SETUP=true playwright test --config=playwright.staging.config.ts"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hookform/resolvers": "^3.9.1",
    "@sentry/react": "^10.56.0",
    "@tanstack/react-query": "^5.59.20",
    "@tanstack/react-virtual": "^3.14.2",
    "axios": "^1.7.7",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "lucide-react": "^0.468.0",
    "posthog-js": "^1.379.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.53.2",
    "react-router-dom": "^6.28.0",
    "write-excel-file": "^4.0.7",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^22.10.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.3",
    "vite": "^6.0.1"
  }
}
