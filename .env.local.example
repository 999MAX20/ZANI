# Zani local development without Docker.
# Copy to .env only for local development.

SECRET_KEY=local-dev-secret-key-change-before-production
DEBUG=True
ENVIRONMENT=local
ALLOW_DEMO_MERCHANT_FLOWS=True
RELEASE=local
LOG_LEVEL=INFO
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# Local fallback: SQLite, so PostgreSQL/Docker are not required for smoke checks.
DATABASE_URL=sqlite:///db.sqlite3
DB_CONN_MAX_AGE=0

# Local Redis. If Redis is not running, keep AUTOMATIONS_RUN_INLINE=True for basic checks.
REDIS_URL=redis://localhost:6379/0
CELERY_TASK_DEFAULT_QUEUE=default
AUTOMATIONS_RUN_INLINE=True

JWT_ACCESS_TOKEN_MINUTES=15
JWT_REFRESH_TOKEN_DAYS=7
AUTH_LOGIN_RATE=10/min
AUTH_REFRESH_RATE=30/min
PUBLIC_API_RATE=120/min
PUBLIC_FORM_RATE=60/min
PUBLIC_WIDGET_RATE=120/min
INTEGRATION_WEBHOOK_RATE=300/min
AI_ASSISTANT_RATE=30/min

CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CORS_ALLOW_CREDENTIALS=False
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

SECURE_SSL_REDIRECT=False
SECURE_PROXY_SSL_HEADER=
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SUPPORT_REQUIRES_GRANT=False
AUDIT_LOG_RETENTION_DAYS=365

STATIC_ROOT=staticfiles
MEDIA_URL=media/
MEDIA_ROOT=media
PRIVATE_MEDIA_ROOT=media/private
MAX_UPLOAD_SIZE_MB=10
IMPORT_MAX_ROWS=5000
EXPORT_SYNC_MAX_ROWS=5000
EXPORT_MAX_ROWS=100000
REPORT_MAX_RANGE_DAYS=366
REPORT_EXPORT_SYNC_MAX_DAYS=90
EXPORT_STALE_SECONDS=900

USE_S3=False
STORAGE_BACKEND=local
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=
AWS_S3_ENDPOINT_URL=
AWS_QUERYSTRING_AUTH=True

SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.05

TELEGRAM_ENABLED=False
TELEGRAM_BASE_API_URL=https://api.telegram.org
TELEGRAM_WEBHOOK_SECRET=
WHATSAPP_ENABLED=False
INSTAGRAM_ENABLED=False

# Central AI assistant provider.
# Paste only OPENROUTER_API_KEY to enable live AI locally.
AI_ENABLED=True
AI_PROVIDER=openrouter
AI_MODEL=openrouter/auto
AI_FAST_MODEL=openrouter/auto
AI_SMART_MODEL=openrouter/auto
AI_CHEAP_MODEL=openrouter/auto
AI_DEFAULT_MODEL_TIER=smart
AI_PROMPT_MODEL_TIERS={"crm_assistant":"smart","lead_reply":"fast","client_summary":"smart","daily_summary":"smart","notification_summary":"cheap"}
AI_TEMPERATURE=0.4
AI_HTTP_TIMEOUT_SECONDS=20
OPENROUTER_API_KEY=replace-with-openrouter-api-key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_SITE_URL=http://localhost:5173
OPENROUTER_APP_NAME=ZANI

EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=Zani <no-reply@zani.local>

VITE_API_URL=http://localhost:8000
VITE_API_BASE_URL=http://localhost:8000/api
VITE_APP_NAME=Zani
VITE_APP_ENV=local
VITE_ENABLE_PLATFORM_ADMIN=true
VITE_ENABLE_AI_ASSISTANT=true
VITE_ENABLE_BOTS=true
