# Zani Render/Supabase staging backend env template.
# Put real values into Render Environment, not into repository files.

SECRET_KEY=replace-with-strong-staging-secret-32-plus-chars
DEBUG=False
ENVIRONMENT=staging
RELEASE=staging-render
LOG_LEVEL=INFO
ALLOWED_HOSTS=zani-9lnp.onrender.com
WEB_CONCURRENCY=1
GUNICORN_TIMEOUT=120

# Recommended for Render + Supabase: use split variables and leave DATABASE_URL empty.
# Django will build the URL and URL-encode the password.
DATABASE_URL=
SUPABASE_PROJECT_REF=jjpenskqmomrbjqofbss
SUPABASE_DB_PASSWORD=replace-with-supabase-database-password-not-anon-key
SUPABASE_DB_CONNECTION_MODE=pooler

# Copy these exact values from Supabase:
# Project Settings -> Database -> Connection string -> Transaction pooler.
SUPABASE_DB_POOLER_HOST=replace-with-pooler-host-from-supabase
SUPABASE_DB_PORT=6543
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=postgres.jjpenskqmomrbjqofbss

# If pooler is unavailable, direct mode can fail on Render IPv6. Use only if verified.
# SUPABASE_DB_CONNECTION_MODE=direct
# SUPABASE_DB_HOST=db.jjpenskqmomrbjqofbss.supabase.co
# SUPABASE_DB_PORT=5432
# SUPABASE_DB_USER=postgres

DB_CONN_MAX_AGE=60

REDIS_URL=redis://default:replace-with-upstash-password@replace-with-upstash-host:6379/0
CELERY_WORKER_CONCURRENCY=2
CELERY_TASK_DEFAULT_QUEUE=default
CELERY_TASK_ACKS_LATE=True
CELERY_WORKER_PREFETCH_MULTIPLIER=1
AUTOMATIONS_RUN_INLINE=False

JWT_ACCESS_TOKEN_MINUTES=15
JWT_REFRESH_TOKEN_DAYS=7
AUTH_LOGIN_RATE=10/min
AUTH_REFRESH_RATE=30/min
PUBLIC_API_RATE=120/min
PUBLIC_FORM_RATE=60/min
PUBLIC_WIDGET_RATE=120/min
INTEGRATION_WEBHOOK_RATE=300/min
AI_ASSISTANT_RATE=30/min

CORS_ALLOWED_ORIGINS=https://zani-1.onrender.com
CORS_ALLOW_CREDENTIALS=False
CSRF_TRUSTED_ORIGINS=https://zani-1.onrender.com

SECURE_PROXY_SSL_HEADER=HTTP_X_FORWARDED_PROTO,https
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True
SUPPORT_REQUIRES_GRANT=True
AUDIT_LOG_RETENTION_DAYS=365

STATIC_ROOT=/app/staticfiles
MEDIA_URL=media/
MEDIA_ROOT=/app/media
PRIVATE_MEDIA_ROOT=/app/media/private
MAX_UPLOAD_SIZE_MB=10

# Keep off until object storage is configured.
USE_S3=False
STORAGE_BACKEND=local
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=
AWS_S3_ENDPOINT_URL=
AWS_QUERYSTRING_AUTH=True

SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.05

TELEGRAM_ENABLED=False
TELEGRAM_BASE_API_URL=https://api.telegram.org
TELEGRAM_WEBHOOK_SECRET=
WHATSAPP_ENABLED=False
INSTAGRAM_ENABLED=False

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_TEMPERATURE=0.4

EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=Zani Staging <no-reply-staging@zani.local>
